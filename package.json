{
  "name": "hytale-generators",
  "description": "Utilities for generating Hytale server assets (JSON, language entries, textures, derived colors, and recipe definitions) into a `dist/` directory.",
  "version": "0.3.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dustinheisey/Hytale-Generators.git"
  },
  "keywords": [
    "hytale",
    "hytale-mod",
    "modding",
    "game-modding",
    "asset-pack",
    "asset-generator",
    "json",
    "textures",
    "sharp",
    "build-tools",
    "node",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "imports": {
    "#hg/*": "./dist/*.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Dustin Heisey",
  "type": "module",
  "scripts": {
    "format": "prettier . --write",
    "typecheck": "tsc -b",
    "lint": "eslint . -c eslint.config.ts && cspell lint .",
    "lint:fix": "eslint . -c eslint.config.ts --fix",
    "clean": "rimraf dist test",
    "build": "tsc -p tsconfig.build.json",
    "prebuild": "npm run clean",
    "test": "tsc -p tsconfig.build.json && node dist/index.test.js",
    "test:clean": "npm run clean && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.3.0",
    "commitlint": "^20.4.2",
    "cspell": "^9.7.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "module-alias": "^2.3.4",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "type-fest": "^5.4.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "dependencies": {
    "culori": "^4.0.2",
    "sharp": "^0.34.5"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "npm run format"
    ],
    "*.{ts,js}": [
      "npm run lint"
    ]
  }
}
